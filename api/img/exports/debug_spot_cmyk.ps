%!PS-Adobe-3.0
%%BoundingBox: 0 0 100 100
%%DocumentColorSpaces: (W1)
%%EndComments
/m { moveto } bind def /l { lineto } bind def
/h { closepath } bind def /f { eofill } bind def
<< /PageSize [100 100] >> setpagedevice
/W1cs [/Separation (W1) /DeviceCMYK {0 0 0 1 mul dup dup dup}] def
1 1 1 setrgbcolor 0 0 100 100 rectfill
W1cs setcolorspace
true setoverprint
1.0 setcolor
newpath 10 10 m 90 10 l 90 90 l 10 90 l h f
showpage
%%EOF
